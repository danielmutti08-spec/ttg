rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /settings/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    
    match /articles/{article} {
      allow read: if true;
      
      // Allow updates to stats and tracking arrays
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['stats', 'likedBy', 'savedBy']);
      
      // Allow admin to write articles (assuming they have access or for seeding)
      allow write: if true;
    }
  }
}
